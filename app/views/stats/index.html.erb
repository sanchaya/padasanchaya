<h1>ಪದ ಸಂಚಯ - ಅಂಕಿಅಂಶಗಳು (Statistics)</h1>

<div class="stats-summary">
  <p><strong>Total Dictionaries:</strong> <%= @total_dictionaries %></p>
  <p><strong>Wiktionary Entries:</strong> <%= number_with_delimiter(@wiktionary_count || 0) %></p>
  <p><strong>Vachana Sanchaya:</strong> <%= number_with_delimiter(@vachana_count || 0) %></p>
  <p><strong>Indic-Dict Stardict:</strong> <%= number_with_delimiter(@stardict_count || 0) %></p>
  <p><strong>Total Entries (Padas):</strong> <%= number_with_delimiter(@total_all_entries || 0) %></p>
</div>

<h3>All Dictionaries</h3>
<table border="1" cellpadding="5" style="border-collapse: collapse; width: 100%; margin-bottom: 30px;">
  <thead style="background-color: #e7f3ff;">
    <tr>
      <th>ID</th>
      <th>Dictionary Name</th>
      <th>Publisher</th>
      <th>Year</th>
      <th>Total Items</th>
    </tr>
  </thead>
  <tbody>
    <% if @dictionaries.present? %>
      <% @dictionaries.each do |dict| %>
        <tr style="border-left: 4px solid <%= %w[#e74c3c #e67e22 #f1c40f #2ecc71 #3498db #9b59b6 #1abc9c #e91e63 #ff5722 #607d8b][(dict.id || 0) % 10] %>;">
          <td><%= dict.id %></td>
          <td><%= dict.name %></td>
          <td><%= dict.publisher.presence || '-' %></td>
          <td><%= dict.published_year || '-' %></td>
          <td align="right"><%= number_with_delimiter(dict.pada_count) %></td>
        </tr>
      <% end %>
    <% else %>
      <tr><td colspan="5" align="center">No dictionaries found.</td></tr>
    <% end %>
  </tbody>
</table>

<h3>Vachana Sanchaya</h3>
<table border="1" cellpadding="5" style="border-collapse: collapse; width: 100%; margin-bottom: 30px;">
  <thead style="background-color: #e8f5e9;">
    <tr>
      <th>Source</th>
      <th>Total Entries</th>
      <th>Link</th>
    </tr>
  </thead>
  <tbody>
    <tr style="border-left: 4px solid #2ecc71;">
      <td>Vachana Sanchaya Glossary</td>
      <td align="right"><%= number_with_delimiter(@vachana_count || 0) %></td>
      <td><a href="https://vachana.sanchaya.net" target="_blank" rel="noopener">vachana.sanchaya.net</a></td>
    </tr>
  </tbody>
</table>

<h3>Indic-Dict Stardict</h3>
<table border="1" cellpadding="5" style="border-collapse: collapse; width: 100%; margin-bottom: 30px;">
  <thead style="background-color: #fff3e0;">
    <tr>
      <th>Dictionary</th>
      <th>Total Entries</th>
      <th>Source</th>
    </tr>
  </thead>
  <tbody>
    <% if @stardict_dictionaries.present? %>
      <% @stardict_dictionaries.each do |dict| %>
        <tr style="border-left: 4px solid #ff9800;">
          <td><%= dict.name %></td>
          <td align="right"><%= number_with_delimiter(@stardict_counts[dict.id] || 0) %></td>
          <td><a href="https://github.com/indic-dict/stardict-kannada" target="_blank" rel="noopener">indic-dict/stardict-kannada</a></td>
        </tr>
      <% end %>
    <% else %>
      <tr><td colspan="3" align="center">No indic-dict dictionaries imported yet. Run <code>rails indic_dict:import</code>.</td></tr>
    <% end %>
  </tbody>
</table>

<h3>Wiktionary</h3>
<table border="1" cellpadding="5" style="border-collapse: collapse; width: 100%;">
  <thead style="background-color: #f0f0f0;">
    <tr>
      <th>Source</th>
      <th>Total Entries</th>
      <th>Link</th>
    </tr>
  </thead>
  <tbody>
    <tr style="border-left: 4px solid #9b59b6;">
      <td>Kannada Wiktionary</td>
      <td align="right"><%= number_with_delimiter(@wiktionary_count || 0) %></td>
      <td><a href="https://kn.wiktionary.org" target="_blank" rel="noopener">kn.wiktionary.org</a></td>
    </tr>
  </tbody>
</table>

<p style="margin-top: 20px; font-size: 12px; color: #666;">
  Wiktionary entries from kn.wiktionary.org. Vachana Sanchaya from vachana.sanchaya.net.
</p>
