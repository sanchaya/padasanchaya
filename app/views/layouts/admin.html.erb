<!DOCTYPE html>
<html>
  <head>
    <title>Admin - <%= t(:pada_kanaja) %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>
  <body>
    <div class="navbar navbar-inverse navbar-static-top">
      <div class="container">
        <div class="navbar-header">
          <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-responsive-collapse">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          <a href="<%= admin_dashboard_path %>" class="navbar-brand">⚙️ Admin - <%= t(:pada_kanaja) %></a>
        </div>
        <% if session[:admin_user_id] %>
          <div class="navbar-collapse collapse navbar-responsive-collapse">
            <ul class="nav navbar-nav">
              <li><%= link_to 'ಡ್ಯಾಶ್ಬೋರ್ಡ್', admin_dashboard_path %></li>
              <li><%= link_to 'ಸಮುದಾಯ ನಮೂದುಗಳು', admin_community_entries_path %></li>
              <li><%= link_to 'ನಿಘಂಟುಗಳು', admin_dictionaries_path %></li>
              <li><%= link_to 'ಸೆಟ್ಟಿಂಗ್‌ಗಳು', admin_settings_path %></li>
              <li><%= link_to 'ಲಾಗೌಟ್', admin_logout_path, method: :delete %></li>
            </ul>
            <p class="navbar-text navbar-right" style="color: #ccc; font-size: 12px;">
              <%= current_admin&.name || current_admin&.email %>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="container" style="min-height: 500px;">
      <%= bootstrap_flash %>
      <%= yield %>
    </div>

    <div class="navbar navbar-fixed-bottom">
      <footer class="footer">
        <div class="container">
          <p style="font-size: 11px; margin: 10px 0; color: #888;">
            <%= link_to '← ಮುಖಪುಟಕ್ಕೆ', root_path %> &nbsp;|&nbsp; Admin Panel - Pada Sanchaya
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
