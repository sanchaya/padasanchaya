  <div class="main-meaning-section" data-meaning-only="<%= @meaning_only_results %>">
    <% has_any_results = (@meanings && @meanings.count > 0) || (@vachana_meanings && @vachana_meanings.any?) || (@alar_meanings && @alar_meanings.any?) || (@wiktionary_meanings && @wiktionary_meanings.any?) || (@jana_sanchaya_meanings && @jana_sanchaya_meanings.any?) %>
    
    <% if has_any_results && params[:search].present? %>
      <h2 style="font-size: 20px;"><i>'<%= params[:search] %>'</i> ಗಾಗಿ ಫಲಿತಾಂಶಗಳು</h2>
      <% if @meaning_only_results %>
        <p style="font-size: 13px; color: #ff9800; margin-bottom: 10px;"><span class="glyphicon glyphicon-alert"></span> ಅರ್ಥದಲ್ಲಿ ಪತ್ತೆಯಾದ ಪದ — ಯಾವುದೇ ನಿಖರ ಪದದ ಹೊಂದಾಣಿಕೆ ಇಲ್ಲ</p>
      <% end %>
    <% end %>

    <% if @meanings && @meanings.count > 0 %>
      <% @meanings.each do |meaning| %>
        <div class="search-result-item">
          <% if meaning.word.present? && meaning.word !~ /^\d+$/ %>
            <h5 style="font-size: 18px; margin-bottom: 5px;"><strong><%= meaning.word %></strong></h5>
          <% end %>
          <p><span class="word-meaning" style="font-size: 20px;"><%= meaning.meaning %></span></p>
          <% if meaning.pos.present? %>
            <p><span class="word-description" style="font-size: 13px;"><%= meaning.pos %></span></p>
          <% end %>
          
          <% if Setting.get('show_dictionary_names') == 'true' && meaning.dictionary.try(:show_name_in_search?) %>
            <p style="font-size: 11px; color: #888; margin: 5px 0 2px 0;">
              <span style="display: inline-block; background: <%= dictionary_color(meaning.dictionary_id) %>22; border-left: 3px solid <%= dictionary_color(meaning.dictionary_id) %>; padding: 1px 8px; border-radius: 2px;">
                <%= meaning.dictionary.name %>
              </span>
            </p>
          <% end %>

          <%# Show extra details for imported dictionaries (dict_id >= 11) %>
          <% if meaning.dictionary_id && meaning.dictionary_id >= 11 %>
            <% if meaning.synonyms.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಪರ್ಯಾಯ ಪದ:</strong> <%= meaning.synonyms %></p>
            <% end %>
            <% if meaning.department.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ವಿಭಾಗ:</strong> <%= meaning.department %></p>
            <% end %>
            <% if meaning.kannada_pronunciation.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಉಚ್ಚಾರಣ:</strong> <%= meaning.kannada_pronunciation %></p>
            <% end %>
            <% if meaning.short_description.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಸಂಕ್ಷಿಪ್ತ ವಿವರಣೆ:</strong> <%= meaning.short_description %></p>
            <% end %>
            <% if meaning.long_description.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ವಿವರಣೆ:</strong> <%= meaning.long_description %></p>
            <% end %>
            <% if meaning.administrative_word.present? %>
              <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಆಡಳಿತ ಪದ:</strong> <%= meaning.administrative_word %></p>
            <% end %>
          <% end %>
          
          <div class="dictionary-underline" style="border-bottom: 3px solid <%= dictionary_color(meaning.dictionary_id) %>"></div>
        </div>
      <% end %>
    <% end %>

    <%# Alar (ಅಲರ್‌) results under horizontal line %>
    <% if @alar_meanings && @alar_meanings.any? %>
      <hr style="margin: 20px 0; border-top: 2px dashed #ccc;" />
      <h5 style="color: #666; font-size: 15px;">
        <span style="background-color: #fff3e0; padding: 3px 8px; border-radius: 4px;">ಅಲರ್‌ - ವಿ. ಕೃಷ್ಣ</span>
      </h5>
      <% @alar_meanings.each do |entry| %>
        <div class="search-result-item">
          <% if entry.word.present? && entry.word !~ /^\d+$/ %>
            <h5 style="font-size: 17px; margin-bottom: 5px;"><strong><%= entry.word %></strong></h5>
          <% end %>
          <p><span class="word-meaning" style="font-size: 20px;"><%= entry.meaning %></span></p>
          <% if entry.pos.present? %>
            <p><span class="word-description" style="font-size: 13px;"><%= entry.pos %></span></p>
          <% end %>
          <% if entry.short_description.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಸಂಕ್ಷಿಪ್ತ ವಿವರಣೆ:</strong> <%= entry.short_description %></p>
          <% end %>
          <% if entry.synonyms.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಪರ್ಯಾಯ ಪದ:</strong> <%= entry.synonyms %></p>
          <% end %>
          <% if entry.department.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ವಿಭಾಗ:</strong> <%= entry.department %></p>
          <% end %>
          <% if entry.kannada_pronunciation.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಉಚ್ಚಾರಣ:</strong> <%= entry.kannada_pronunciation %></p>
          <% end %>
          <% if entry.long_description.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ವಿವರಣೆ:</strong> <%= entry.long_description %></p>
          <% end %>
          <% if entry.administrative_word.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0;"><strong>ಆಡಳಿತ ಪದ:</strong> <%= entry.administrative_word %></p>
          <% end %>
          <div class="dictionary-underline" style="border-bottom: 3px solid #e67e22;"></div>
        </div>
      <% end %>
    <% end %>

    <%# Vachana Sanchaya results under horizontal line %>
    <% if @vachana_meanings && @vachana_meanings.any? %>
      <hr style="margin: 20px 0; border-top: 2px dashed #ccc;" />
      <h5 style="color: #666; font-size: 15px;">
        <span style="background-color: #e8f5e9; padding: 3px 8px; border-radius: 4px;">Vachana Sanchaya</span>
      </h5>
      <% @vachana_meanings.each do |entry| %>
        <div class="search-result-item">
          <% if entry.word.present? && entry.word !~ /^\d+$/ %>
            <h5 style="font-size: 17px; margin-bottom: 5px;"><strong><%= entry.word %></strong></h5>
          <% end %>
          <p><span class="word-meaning" style="font-size: 20px;"><%= entry.meaning %></span></p>
          <% if entry.pos.present? %>
            <p><span class="word-description" style="font-size: 13px;"><%= entry.pos %></span></p>
          <% end %>
          <p style="font-size: 12px; color: #888;">
            ಮೂಲ: <a href="<%= URI.encode_www_form_component(entry.word) %>" target="_blank" rel="noopener">vachana.sanchaya.net</a>
          </p>
          <div class="dictionary-underline" style="border-bottom: 3px solid #2ecc71;"></div>
        </div>
      <% end %>
    <% end %>

    <%# Wiktionary results under horizontal line %>
    <% if @wiktionary_meanings && @wiktionary_meanings.any? %>
      <hr style="margin: 20px 0; border-top: 2px dashed #ccc;" />
      <h5 style="color: #666; font-size: 15px;">
        <span style="background-color: #e7f3ff; padding: 3px 8px; border-radius: 4px;">Wiktionary</span>
      </h5>
      <% @wiktionary_meanings.each do |entry| %>
        <div class="search-result-item">
          <p><span class="word-meaning" style="font-size: 20px;"><%= entry.meaning %></span></p>
          <% if entry.pos.present? %>
            <p><span class="word-description" style="font-size: 13px;"><%= entry.pos %></span></p>
          <% end %>
          <p style="font-size: 12px; color: #888;">
            ಮೂಲ: <a href="https://kn.wiktionary.org/wiki/<%= URI.encode_www_form_component(entry.page_title) %>" target="_blank" rel="noopener">kn.wiktionary.org/wiki/<%= entry.page_title %></a>
          </p>
          <div class="dictionary-underline" style="border-bottom: 3px solid #9b59b6;"></div>
        </div>
      <% end %>
    <% end %>

    <%# JanaSanchaya community results under horizontal line %>
    <% if @jana_sanchaya_meanings && @jana_sanchaya_meanings.any? %>
      <hr style="margin: 20px 0; border-top: 2px dashed #ccc;" />
      <h5 style="color: #666; font-size: 15px;">
        <span style="background-color: #f3e5f5; padding: 3px 8px; border-radius: 4px;">ಜನಸಂಚಯ - ಸಮುದಾಯ ನಿಘಂಟು</span>
      </h5>
      <% @jana_sanchaya_meanings.each do |entry| %>
        <div class="search-result-item" data-entry-id="<%= entry.id %>">
          <h5 style="font-size: 17px; margin-bottom: 3px;"><strong><%= entry.word %></strong></h5>
          <% if entry.transliteration.present? %>
            <span style="font-size: 12px; color: #888;">/<%= entry.transliteration %>/</span>
          <% end %>
          <p><span class="word-meaning" style="font-size: 20px;"><%= entry.meaning %></span></p>
          <% if entry.meaning_in_english.present? %>
            <p style="font-size: 14px; color: #555; font-style: italic;"><%= entry.meaning_in_english %></p>
          <% end %>
          <% if entry.pos.present? %>
            <p><span class="word-description" style="font-size: 13px;"><%= entry.pos %></span></p>
          <% end %>

          <%# Dialect tag %>
          <% if entry.is_dialect && (entry.dialect&.kannada_name || entry.dialect_name).present? %>
            <span style="display: inline-block; background: #fff8e1; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #f57f17; margin-bottom: 5px;">
              🏷️ <%= entry.dialect&.kannada_name || entry.dialect_name %><% if entry.dialect_place.present? %> (<%= entry.dialect_place %>)<% end %>
            </span>
          <% end %>

          <%# Ecological domain tag %>
          <% if entry.ecological_domain.present? %>
            <span style="display: inline-block; background: #e8f5e9; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #2e7d32; margin-bottom: 5px; margin-left: 5px;">
              🌿 <%= entry.ecological_domain %>
            </span>
          <% end %>

          <%# Etymology tag %>
          <% if entry.root_language.present? %>
            <span style="display: inline-block; background: #fce4ec; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #c62828; margin-bottom: 5px; margin-left: 5px;">
              📖 <%= entry.root_language %><% if entry.root_word.present? %>: <%= entry.root_word %><% end %>
            </span>
          <% end %>

          <%# Thesaurus fields %>
          <% if entry.synonyms.present? %>
            <p style="font-size: 12px; color: #1565c0; margin: 3px 0;"><strong>ಪರ್ಯಾಯ ಪದಗಳು:</strong> <%= entry.synonyms %></p>
          <% end %>
          <% if entry.antonyms.present? %>
            <p style="font-size: 12px; color: #c62828; margin: 3px 0;"><strong>ವಿರುದ್ಧಾರ್ಥಕ:</strong> <%= entry.antonyms %></p>
          <% end %>
          <% if entry.usage_example.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0; font-style: italic;">"<%= entry.usage_example %>"</p>
          <% end %>
          <% if entry.cognates.present? %>
            <p style="font-size: 12px; color: #e91e63; margin: 3px 0;"><strong>ಸಹಜ ಪದಗಳು:</strong> <%= entry.cognates %></p>
          <% end %>
          <% if entry.etymology.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0; background: #fce4ec; padding: 3px 6px; border-radius: 4px;"><strong>📖 ವ್ಯುತ್ಪತ್ತಿ:</strong> <%= entry.etymology %></p>
          <% end %>
          <% if entry.cultural_notes.present? %>
            <p style="font-size: 12px; color: #555; margin: 3px 0; background: #fff3e0; padding: 3px 6px; border-radius: 4px;"><strong>📝</strong> <%= entry.cultural_notes %></p>
          <% end %>

          <%# Contributor info %>
          <p style="font-size: 11px; color: #aaa; margin: 3px 0;">
            <%= entry.contributor_name.presence || '' %>
            <% if entry.current_place.present? %><% if entry.contributor_name.present? %> | <% end %>📍 <%= entry.current_place %><% end %>
          </p>

          <%# Voting buttons %>
          <div class="voting-section" style="margin-top: 8px;">
            <button type="button" class="btn btn-sm btn-default jana-vote-up" data-entry-id="<%= entry.id %>" style="margin-right: 5px;" title="ಒಪ್ಪಿಕೊಳ್ಳು (Agree)">
              <span class="glyphicon glyphicon-thumbs-up" style="color: #4caf50;"></span>
              <span class="vote-count-up"><%= entry.votes_up %></span>
            </button>
            <button type="button" class="btn btn-sm btn-default jana-vote-down" data-entry-id="<%= entry.id %>" style="margin-right: 10px;" title="ಅಸಮ್ಮತಿ (Disagree)">
              <span class="glyphicon glyphicon-thumbs-down" style="color: #f44336;"></span>
              <span class="vote-count-down"><%= entry.votes_down %></span>
            </button>
            <span class="vote-message" style="font-size: 11px; color: #888;"></span>
          </div>
          <div class="dictionary-underline" style="border-bottom: 3px solid #9c27b0; margin-top: 10px;"></div>
        </div>
      <% end %>
    <% end %>

    <%# No results message + Contribution form %>
    <% if !has_any_results %>
      <% if params[:search].present? %>
        <p><span class="word-description" style="font-size: 15px;"> ಯಾವುದೆ ಅರ್ಥ ದೊರೆತಿಲ್ಲ </span></p>
        
        <%# Contribution form for JanaSanchaya %>
        <div style="margin-top: 25px; padding: 20px; background: #f5f5f5; border-radius: 8px; border-left: 4px solid #ff9800;">
          <h5 style="color: #e65100; margin-bottom: 15px;"><span class="glyphicon glyphicon-hand-right"></span> ಇದಕ್ಕೆ ಅರ್ಥ ಕೊಡಿ - ಸಮುದಾಯ ನಿಘಂಟಿಗೆ ಸೇರಿಸಿ</h5>
          <p style="font-size: 13px; color: #666; margin-bottom: 15px;">
            ನಿಮಗೆ '<%= params[:search] %>' ಎಂಬ ಪದದ ಅರ್ಥ ತಿಳಿದಿದೆಯೇ? ಕೆಳಗಿನ ವಿವರಗಳನ್ನು ಭರ್ತಿ ಮಾಡಿ.
            ಹೆಚ್ಚಿನ ಮಾಹಿತಿಗಾಗಿ <a href="<%= contribute_path(word: params[:search]) %>" style="color: #e65100;">ಪೂರ್ಣ ನಮೂನೆ</a> ಬಳಸಿ.
          </p>
          <%= form_with url: jana_sanchaya_entries_path, method: :post, local: true do |f| %>
            <%= hidden_field_tag :search_word, params[:search] %>
            <div class="form-group">
              <label style="font-size: 13px;">ಪದ (Word)</label>
              <%= text_field_tag 'jana_sanchaya_entry[word]', params[:search], class: 'form-control', style: 'font-size: 14px;', readonly: true %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಅರ್ಥ (Meaning) *</label>
              <%= text_area_tag 'jana_sanchaya_entry[meaning]', '', class: 'form-control', style: 'font-size: 14px;', rows: 2, required: true, placeholder: 'ಇಲ್ಲಿ ಅರ್ಥ ಬರೆಯಿರಿ...' %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಪದವರ್ಗ (POS)</label>
              <%= select_tag 'jana_sanchaya_entry[pos]', options_for_select(JanaSanchayaEntry::POS_TYPES), { prompt: 'ಆಯ್ಕೆ ಮಾಡಿ', class: 'form-control', style: 'font-size: 13px;' } %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಪರ್ಯಾಯ ಪದಗಳು (Synonyms)</label>
              <%= text_field_tag 'jana_sanchaya_entry[synonyms]', '', class: 'form-control', style: 'font-size: 14px;', placeholder: 'ಸಮಾನಾರ್ಥಕ ಪದಗಳು, ಅಲ್ಪವಿರಾಮದಿಂದ ಪ್ರತ್ಯೇಕಿಸಿ' %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಮೂಲ ಭಾಷೆ (Root Language)</label>
              <%= select_tag 'jana_sanchaya_entry[root_language]', options_for_select(JanaSanchayaEntry::ROOT_LANGUAGES), { prompt: 'ಪದದ ಮೂಲ ಭಾಷೆ', class: 'form-control', style: 'font-size: 13px;' } %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಉಪಭಾಷೆಯ ಹೆಸರು (Dialect) - ಐಚ್ಛಿಕ</label>
              <%= text_field_tag 'jana_sanchaya_entry[dialect_name]', '', class: 'form-control', style: 'font-size: 14px;', placeholder: 'ಉದಾ: ಆರೆಭಾಷೆ, ಹವ್ಯಕ, ಸೊಲಿಗ...' %>
            </div>
            <div class="form-group">
              <label style="font-size: 13px;">ಉಪಭಾಷೆಯ ಪ್ರದೇಶ</label>
              <%= text_field_tag 'jana_sanchaya_entry[dialect_place]', '', class: 'form-control', style: 'font-size: 14px;', placeholder: 'ಯಾವ ಊರು/ಜಿಲ್ಲೆಯಲ್ಲಿ ಈ ಪದ ಬಳಕೆಯಲ್ಲಿದೆ?' %>
            </div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
              <div style="flex: 1; min-width: 150px;">
                <label style="font-size: 12px; display: block;">
                  <%= check_box_tag 'jana_sanchaya_entry[is_dialect]', '1', false %> ಇದು ಉಪಭಾಷೆಯ ಪದ
                </label>
              </div>
              <div style="flex: 1; min-width: 150px;">
                <label style="font-size: 12px;">ಪರಿಸರ ಕ್ಷೇತ್ರ</label>
                <%= select_tag 'jana_sanchaya_entry[ecological_domain]', options_for_select(JanaSanchayaEntry::ECOLOGICAL_DOMAINS), { prompt: 'ಆಯ್ಕೆ ಮಾಡಿ', class: 'form-control', style: 'font-size: 12px;' } %>
              </div>
            </div>
            <div style="margin-top: 10px;">
              <%= submit_tag 'ಸೇರಿಸಿ (Submit)', class: 'btn btn-warning btn-sm', style: 'font-size: 14px;' %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# Show more button for meaning-only search %>
    <% if @meaning_only_results %>
      <div id="show-more-container" style="text-align: center; margin-top: 20px; display: none;">
        <button id="show-more-btn" class="btn btn-default btn-sm" style="font-size: 14px; background: #f0f0f0; border-color: #ccc;">
          <span class="glyphicon glyphicon-chevron-down"></span> ಮತ್ತಷ್ಟು
        </button>
      </div>
    <% end %>
  </div>

  <script>
  (function() {
    // Handle meaning-only search: show only first 5 results, rest on-demand
    var container = document.querySelector('.main-meaning-section');
    if (container && container.getAttribute('data-meaning-only') === 'true') {
      var items = container.querySelectorAll('.search-result-item');
      if (items.length > 5) {
        for (var i = 5; i < items.length; i++) {
          items[i].style.display = 'none';
        }
        var showMoreContainer = document.getElementById('show-more-container');
        var showMoreBtn = document.getElementById('show-more-btn');
        if (showMoreContainer) {
          showMoreContainer.style.display = 'block';
        }
        if (showMoreBtn) {
          showMoreBtn.addEventListener('click', function() {
            for (var j = 5; j < items.length; j++) {
              items[j].style.display = 'block';
            }
            showMoreContainer.style.display = 'none';
          });
        }
      }
    }

    // Handle JanaSanchaya vote buttons via AJAX
    document.querySelectorAll('.jana-vote-up, .jana-vote-down').forEach(function(button) {
      button.addEventListener('click', function() {
        var entryId = this.getAttribute('data-entry-id');
        var isUp = this.classList.contains('jana-vote-up');
        var voteType = isUp ? 'up' : 'down';
        var container = this.closest('.voting-section');
        var messageEl = container.querySelector('.vote-message');
        
        fetch('/jana_sanchaya_entries/' + entryId + '/vote', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : ''
          },
          body: JSON.stringify({ vote_type: voteType })
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
          if (data.success) {
            container.querySelector('.vote-count-up').textContent = data.votes_up;
            container.querySelector('.vote-count-down').textContent = data.votes_down;
            messageEl.textContent = 'ಧನ್ಯವಾದಗಳು! (Thank you!)';
            messageEl.style.color = '#4caf50';
          } else {
            messageEl.textContent = 'ಈಗಾಗಲೇ ಮತದಾನ ಮಾಡಿದ್ದೀರಿ (Already voted)';
            messageEl.style.color = '#ff9800';
          }
        })
        .catch(function() {
          messageEl.textContent = 'ದೋಷ ಸಂಭವಿಸಿದೆ (Error)';
          messageEl.style.color = '#f44336';
        });
      });
    });
  })();
  </script>
