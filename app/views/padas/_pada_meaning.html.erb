  <div class="main-meaning-section">
    <% if @meanings.count > 0 %>
      <h4>  <i> '<%= @meanings.first.word %>' </i>  ಪದದ ಅರ್ಥ</h4>

     <% @meanings.each do |meaning| %>
       <p> <span class="word-meaning"> <%= meaning.meaning %> </span> </p>
        <p> <span class="word-description"> <%= meaning.pos %> </span> </p>
        <div class="dictionary-underline" style="border-bottom: 3px solid <%= dictionary_color(meaning.dictionary_id) %>"></div>
      <% end %>
    <% elsif @wiktionary_meanings && @wiktionary_meanings.count > 0 %>
      <%# Wiktionary results will show below; no "not found" message here %>
    <% else %>
      <p> <span class="word-description"> ಯಾವುದೆ ಅರ್ಥ ದೊರೆತಿಲ್ಲ </span> </p>
    <% end %>

    <%# Wiktionary results under horizontal line %>
    <% if @wiktionary_meanings && @wiktionary_meanings.count > 0 %>
      <hr style="margin: 25px 0; border-top: 2px dashed #ccc;" />
      <h5 style="color: #666;">
        <span style="background-color: #e7f3ff; padding: 3px 8px; border-radius: 4px;">Wiktionary</span>
      </h5>
      <% @wiktionary_meanings.each do |entry| %>
        <p> <span class="word-meaning"> <%= entry.meaning %> </span> </p>
        <p> <span class="word-description"> <%= entry.pos %> </span> </p>
        <p style="font-size: 12px; color: #888;">
          ಮೂಲ: <a href="https://kn.wiktionary.org/wiki/<%= URI.encode_www_form_component(entry.page_title) %>" target="_blank" rel="noopener">kn.wiktionary.org/wiki/<%= entry.page_title %></a>
        </p>
        <div class="dictionary-underline" style="border-bottom: 3px solid #9b59b6;"></div>
      <% end %>
    <% end %>
  </div>
