<h2><%= @dictionary.name %>
  <%= link_to 'ಸಂಪಾದಿಸು', edit_admin_dictionary_path(@dictionary), class: 'btn btn-xs btn-warning', style: 'font-size: 14px;' %>
</h2>

<div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 15px 0; display: flex; gap: 30px; flex-wrap: wrap; font-size: 13px;">
  <div><strong>ಮೂಲ ಹೆಸರು:</strong> <%= @dictionary.core_name.presence || @dictionary.original_name.presence || '-' %></div>
  <div><strong>ಪ್ರಕಾರ:</strong> <%= @dictionary.dictionary_type.presence || '-' %></div>
  <div><strong>ವರ್ಗ:</strong> <%= @dictionary.category.presence || '-' %></div>
  <div><strong>ಬಹುಭಾಷಾ:</strong> <%= @dictionary.multilingual? ? 'ಹೌದು' : 'ಇಲ್ಲ' %></div>
  <div><strong>ಪ್ರಕಾಶಕರು:</strong> <%= @dictionary.publisher.presence || '-' %></div>
  <div><strong>ಪ್ರಕಾಶನ ವರ್ಷ:</strong> <%= @dictionary.published_year || '-' %></div>
  <div><strong>ಒಟ್ಟು ನಮೂದುಗಳು:</strong> <%= @dictionary.total_entries || Pada.where(dictionary_id: @dictionary.id).count %></div>
  <div><strong>ಹುಡುಕಾಟದಲ್ಲಿ ತೋರಿಸು:</strong>
    <span style="color: <%= @dictionary.show_name_in_search? ? '#4caf50' : '#999' %>; font-weight: bold;">
      <%= @dictionary.show_name_in_search? ? 'ಹೌದು' : 'ಇಲ್ಲ' %>
    </span>
  </div>
</div>

<% if @dictionary.description.present? %>
  <div style="background: #fff; padding: 10px 15px; border: 1px solid #ddd; border-radius: 8px; margin: 15px 0; font-size: 13px;">
    <strong>ವಿವರಣೆ:</strong> <%= @dictionary.description %>
  </div>
<% end %>

<div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 15px 0;">
  <%= form_tag admin_dictionary_path(@dictionary), method: :get, style: 'display: flex; gap: 10px; align-items: flex-end;' do %>
    <div>
      <%= label_tag :search, 'ಪದ ಹುಡುಕು', style: 'font-size: 12px;' %>
      <%= text_field_tag :search, params[:search], class: 'form-control input-sm', placeholder: 'ಪದ...' %>
    </div>
    <div><%= submit_tag 'ಹುಡುಕು', class: 'btn btn-sm btn-primary' %></div>
  <% end %>
</div>

<p><%= @entries.count %> ನಮೂದುಗಳು</p>

<table class="table table-striped table-hover" style="font-size: 12px;">
  <thead>
    <tr>
      <th>ID</th>
      <th>ಪದ</th>
      <th>ಅರ್ಥ</th>
      <th>ಪದವರ್ಗ</th>
      <th>ಮೂಲ ಭಾಷೆ</th>
      <th>ಸಂಕ್ಷಿಪ್ತ ವಿವರಣೆ</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |pada| %>
      <tr>
        <td><%= pada.id %></td>
        <td><strong><%= pada.word %></strong></td>
        <td><%= truncate(pada.meaning, length: 40) %></td>
        <td><%= pada.pos.presence || '-' %></td>
        <td><%= pada.root_language.presence || '-' %></td>
        <td><%= truncate(pada.short_description, length: 40) if pada.short_description.present? %></td>
        <td><%= link_to 'ಸಂಪಾದಿಸು', edit_entry_admin_dictionary_path(dictionary_id: @dictionary.id, id: pada.id), class: 'btn btn-xs btn-warning' %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @entries if @entries.respond_to?(:total_pages) %>

<%= link_to 'ಹಿಂದೆ', admin_dictionaries_path, class: 'btn btn-default' %>
