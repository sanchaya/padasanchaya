<h2><%= @dictionary.name %>
  <%= link_to 'ಸಂಪಾದಿಸು', edit_admin_dictionary_path(@dictionary), class: 'btn btn-xs btn-warning', style: 'font-size: 14px;' %>
</h2>

<%# Metadata panel %>
<div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 15px 0; display: flex; gap: 30px; flex-wrap: wrap; font-size: 13px;">
  <div><strong>ಮೂಲ ಹೆಸರು:</strong> <%= @dictionary.core_name.presence || @dictionary.original_name.presence || '-' %></div>
  <div><strong>ಪ್ರಕಾರ:</strong> <%= @dictionary.dictionary_type.presence || '-' %></div>
  <div><strong>ವರ್ಗ:</strong> <%= @dictionary.category.presence || '-' %></div>
  <div><strong>ಬಹುಭಾಷಾ:</strong> <%= @dictionary.multilingual? ? 'ಹೌದು' : 'ಇಲ್ಲ' %></div>
  <div><strong>ಪ್ರಕಾಶಕರು:</strong> <%= @dictionary.publisher.presence || '-' %></div>
  <div><strong>ಪ್ರಕಾಶನ ವರ್ಷ:</strong> <%= @dictionary.published_year || '-' %></div>
  <div><strong>ಒಟ್ಟು ನಮೂದುಗಳು:</strong> <%= @dictionary.total_entries || @total_padas %></div>
  <div><strong>ಹುಡುಕಾಟದಲ್ಲಿ ತೋರಿಸು:</strong>
    <span style="color: <%= @dictionary.show_name_in_search? ? '#4caf50' : '#999' %>; font-weight: bold;">
      <%= @dictionary.show_name_in_search? ? 'ಹೌದು' : 'ಇಲ್ಲ' %>
    </span>
  </div>
</div>

<% if @dictionary.description.present? %>
  <div style="background: #fff; padding: 10px 15px; border: 1px solid #ddd; border-radius: 8px; margin: 15px 0; font-size: 13px;">
    <strong>ವಿವರಣೆ:</strong> <%= @dictionary.description %>
  </div>
<% end %>

<%# Stats cards %>
<div style="display: flex; gap: 12px; margin: 15px 0; flex-wrap: wrap;">
  <div style="flex: 1; min-width: 120px; background: #e3f2fd; padding: 12px; border-radius: 8px; text-align: center;">
    <div style="font-size: 24px; font-weight: bold; color: #1565c0;"><%= number_with_delimiter(@total_padas) %></div>
    <div style="font-size: 11px; color: #555;">ಒಟ್ಟು ನಮೂದುಗಳು</div>
  </div>
  <div style="flex: 1; min-width: 120px; background: #e8f5e9; padding: 12px; border-radius: 8px; text-align: center;">
    <div style="font-size: 24px; font-weight: bold; color: #2e7d32;"><%= @entries_with_pos %></div>
    <div style="font-size: 11px; color: #555;">ಪದವರ್ಗ (POS) ಹೊಂದಿವೆ</div>
  </div>
  <div style="flex: 1; min-width: 120px; background: #fff3e0; padding: 12px; border-radius: 8px; text-align: center;">
    <div style="font-size: 24px; font-weight: bold; color: #e65100;"><%= @entries_with_root_lang %></div>
    <div style="font-size: 11px; color: #555;">ಮೂಲ ಭಾಷೆ ಹೊಂದಿವೆ</div>
  </div>
  <div style="flex: 1; min-width: 120px; background: #fce4ec; padding: 12px; border-radius: 8px; text-align: center;">
    <div style="font-size: 24px; font-weight: bold; color: #c62828;"><%= @entries_with_synonyms %></div>
    <div style="font-size: 11px; color: #555;">ಪರ್ಯಾಯ ಪದಗಳು</div>
  </div>
</div>

<%# Distribution sections %>
<div style="display: flex; gap: 20px; margin: 15px 0; flex-wrap: wrap;">
  <% if @pos_distribution.present? %>
    <div style="flex: 1; min-width: 250px; background: #f9f9f9; padding: 12px; border-radius: 8px;">
      <h5 style="margin: 0 0 10px 0; font-size: 14px;">ಪದವರ್ಗ ವಿತರಣೆ (Top 10)</h5>
      <% max_count = @pos_distribution.values.first.to_f %>
      <% @pos_distribution.each do |pos, count| %>
        <div style="margin: 4px 0; display: flex; align-items: center; gap: 8px;">
          <span style="font-size: 11px; min-width: 100px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><%= pos %></span>
          <div style="flex: 1; height: 16px; background: #e0e0e0; border-radius: 3px; overflow: hidden;">
            <div style="width: <%= (count / max_count * 100).round %>% ; height: 100%; background: #1565c0; border-radius: 3px;"></div>
          </div>
          <span style="font-size: 11px; color: #555; min-width: 40px; text-align: right;"><%= count %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @root_language_distribution.present? %>
    <div style="flex: 1; min-width: 250px; background: #f9f9f9; padding: 12px; border-radius: 8px;">
      <h5 style="margin: 0 0 10px 0; font-size: 14px;">ಮೂಲ ಭಾಷೆ ವಿತರಣೆ (Top 10)</h5>
      <% max_count = @root_language_distribution.values.first.to_f %>
      <% @root_language_distribution.each do |lang, count| %>
        <div style="margin: 4px 0; display: flex; align-items: center; gap: 8px;">
          <span style="font-size: 11px; min-width: 80px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><%= lang %></span>
          <div style="flex: 1; height: 16px; background: #e0e0e0; border-radius: 3px; overflow: hidden;">
            <div style="width: <%= (count / max_count * 100).round %>% ; height: 100%; background: #e65100; border-radius: 3px;"></div>
          </div>
          <span style="font-size: 11px; color: #555; min-width: 40px; text-align: right;"><%= count %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# Search and entries %>
<div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 15px 0;">
  <%= form_tag admin_dictionary_path(@dictionary), method: :get, style: 'display: flex; gap: 10px; align-items: flex-end;' do %>
    <div>
      <%= label_tag :search, 'ಪದ ಹುಡುಕು', style: 'font-size: 12px;' %>
      <%= text_field_tag :search, params[:search], class: 'form-control input-sm', placeholder: 'ಪದ...' %>
    </div>
    <div><%= submit_tag 'ಹುಡುಕು', class: 'btn btn-sm btn-primary' %></div>
  <% end %>
</div>

<p><%= @entries.count %> ನಮೂದುಗಳು (<%= @total_padas %> ಒಟ್ಟು)</p>

<table class="table table-striped table-hover" style="font-size: 12px;">
  <thead>
    <tr>
      <th>ID</th>
      <th>ಪದ</th>
      <th>ಅರ್ಥ</th>
      <th>ಪದವರ್ಗ</th>
      <th>ಮೂಲ ಭಾಷೆ</th>
      <th>ಸಂಕ್ಷಿಪ್ತ ವಿವರಣೆ</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |pada| %>
      <tr>
        <td><%= pada.id %></td>
        <td><strong><%= pada.word %></strong></td>
        <td><%= truncate(pada.meaning, length: 40) %></td>
        <td>
          <% if pada.pos.present? %>
            <span style="display: inline-block; background: #e3f2fd; padding: 1px 6px; border-radius: 3px; font-size: 11px; color: #1565c0;"><%= pada.pos %></span>
          <% else %>
            -
          <% end %>
        </td>
        <td>
          <% if pada.root_language.present? %>
            <span style="display: inline-block; background: #fce4ec; padding: 1px 6px; border-radius: 3px; font-size: 11px; color: #c62828;"><%= pada.root_language %></span>
          <% else %>
            -
          <% end %>
        </td>
        <td><%= truncate(pada.short_description, length: 40) if pada.short_description.present? %></td>
        <td><%= link_to 'ಸಂಪಾದಿಸು', edit_entry_admin_dictionary_path(dictionary_id: @dictionary.id, id: pada.id), class: 'btn btn-xs btn-warning' %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @entries if @entries.respond_to?(:total_pages) %>

<%= link_to 'ಹಿಂದೆ', admin_dictionaries_path, class: 'btn btn-default' %>
