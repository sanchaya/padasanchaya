<h2>ಆಡ್ಮಿನ್ ಡ್ಯಾಶ್ಬೋರ್ಡ್</h2>

<div class="row" style="margin: 20px 0;">
  <div class="col-md-3">
    <div style="background: #e3f2fd; padding: 20px; border-radius: 8px; text-align: center;">
      <h3 style="margin: 0; font-size: 36px; color: #1565c0;"><%= @pending_entries %></h3>
      <p style="margin: 5px 0 0 0; font-size: 13px;">ಬಾಕಿ ಇರುವ ನಮೂದುಗಳು</p>
      <%= link_to 'ನಿರ್ವಹಿಸಿ', admin_community_entries_path(status: 'pending'), class: 'btn btn-sm btn-primary', style: 'margin-top: 10px;' %>
    </div>
  </div>
  <div class="col-md-3">
    <div style="background: #e8f5e9; padding: 20px; border-radius: 8px; text-align: center;">
      <h3 style="margin: 0; font-size: 36px; color: #2e7d32;"><%= @approved_entries %></h3>
      <p style="margin: 5px 0 0 0; font-size: 13px;">ಅನುಮೋದಿತ ನಮೂದುಗಳು</p>
    </div>
  </div>
  <div class="col-md-3">
    <div style="background: #fce4ec; padding: 20px; border-radius: 8px; text-align: center;">
      <h3 style="margin: 0; font-size: 36px; color: #c62828;"><%= @total_community_entries %></h3>
      <p style="margin: 5px 0 0 0; font-size: 13px;">ಒಟ್ಟು ಸಮುದಾಯ ನಮೂದುಗಳು</p>
    </div>
  </div>
  <div class="col-md-3">
    <div style="background: #fff3e0; padding: 20px; border-radius: 8px; text-align: center;">
      <h3 style="margin: 0; font-size: 36px; color: #e65100;"><%= @total_dictionaries %></h3>
      <p style="margin: 5px 0 0 0; font-size: 13px;">ನಿಘಂಟುಗಳು (<%= @total_pada_entries %> ನಮೂದುಗಳು)</p>
    </div>
  </div>
</div>

<hr>

<h4>ಇತ್ತೀಚಿನ ಸಮುದಾಯ ನಮೂದುಗಳು</h4>
<table class="table table-striped table-hover" style="font-size: 13px;">
  <thead>
    <tr>
      <th>ಪದ</th>
      <th>ಅರ್ಥ</th>
      <th>ಸ್ಥಿತಿ</th>
      <th>ಉಪಭಾಷೆ</th>
      <th>ಮೂಲ ಭಾಷೆ</th>
      <th>ಕೊಡುಗೆದಾರ</th>
      <th>ದಿನಾಂಕ</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @recent_entries.each do |entry| %>
      <tr>
        <td><strong><%= entry.word %></strong></td>
        <td><%= truncate(entry.meaning, length: 40) %></td>
        <td>
          <span style="background: <%= entry.status == 'approved' ? '#e8f5e9' : entry.status == 'pending' ? '#fff8e1' : '#ffebee' %>; padding: 2px 6px; border-radius: 4px; font-size: 11px;">
            <%= entry.status || 'pending' %>
          </span>
        </td>
        <td><%= entry.dialect_name.presence || '-' %></td>
        <td><%= entry.root_language.presence || '-' %></td>
        <td><%= entry.contributor_name.presence || entry.user_ip %></td>
        <td><%= entry.created_at.strftime('%d-%m-%Y') %></td>
        <td><%= link_to 'ಸಂಪಾದಿಸು', edit_admin_community_entry_path(entry), class: 'btn btn-xs btn-default' %></td>
      </tr>
    <% end %>
  </tbody>
</table>
