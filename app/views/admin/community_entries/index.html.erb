<h2>ಸಮುದಾಯ ನಮೂದುಗಳು</h2>

<div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 15px 0;">
  <%= form_tag admin_community_entries_path, method: :get, style: 'display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;' do %>
    <div style="min-width: 120px;">
      <%= label_tag :status, 'ಸ್ಥಿತಿ', style: 'font-size: 12px;' %>
      <%= select_tag :status, options_for_select([['pending','pending'],['approved','approved'],['rejected','rejected']], params[:status]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
    </div>
    <div style="min-width: 120px;">
      <%= label_tag :dialect, 'ಉಪಭಾಷೆ', style: 'font-size: 12px;' %>
      <%= select_tag :dialect, options_for_select(Dialect.alphabetical.pluck(:kannada_name, :id), params[:dialect]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
    </div>
    <div style="min-width: 120px;">
      <%= label_tag :root_language, 'ಮೂಲ ಭಾಷೆ', style: 'font-size: 12px;' %>
      <%= select_tag :root_language, options_for_select(JanaSanchayaEntry::ROOT_LANGUAGES, params[:root_language]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
    </div>
    <div>
      <%= submit_tag 'ಫಿಲ್ಟರ್', class: 'btn btn-sm btn-primary' %>
    </div>
  <% end %>
</div>

<p><%= @entries.count %> ನಮೂದುಗಳು</p>

<table class="table table-striped table-hover" style="font-size: 12px;">
  <thead>
    <tr>
      <th>ID</th>
      <th>ಪದ</th>
      <th>ಅರ್ಥ</th>
      <th>ಸ್ಥಿತಿ</th>
      <th>ಉಪಭಾಷೆ</th>
      <th>ಮೂಲ ಭಾಷೆ</th>
      <th>ಪರಿಸರ</th>
      <th>ವೋಟ್</th>
      <th>ಕೊಡುಗೆದಾರ</th>
      <th>ದಿನಾಂಕ</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |entry| %>
      <tr>
        <td><%= entry.id %></td>
        <td><strong><%= entry.word %></strong></td>
        <td><%= truncate(entry.meaning, length: 30) %></td>
        <td>
          <span style="background: <%= entry.status == 'approved' ? '#e8f5e9' : entry.status == 'pending' ? '#fff8e1' : '#ffebee' %>; padding: 2px 6px; border-radius: 4px;">
            <%= entry.status || 'pending' %>
          </span>
        </td>
        <td><%= entry.dialect_name.presence || '-' %></td>
        <td><%= entry.root_language.presence || '-' %></td>
        <td><%= entry.ecological_domain.presence || '-' %></td>
        <td><%= entry.votes_up %>/<%= entry.votes_down %></td>
        <td><%= entry.contributor_name.presence || truncate(entry.user_ip.to_s, length: 10) %></td>
        <td><%= entry.created_at.strftime('%d-%m-%Y') %></td>
        <td>
          <%= link_to 'ವೀಕ್ಷಿಸು', admin_community_entry_path(entry), class: 'btn btn-xs btn-info' %>
          <%= link_to 'ಸಂಪಾದಿಸು', edit_admin_community_entry_path(entry), class: 'btn btn-xs btn-warning' %>
          <%= link_to 'ಅಳಿಸು', admin_community_entry_path(entry), method: :delete, data: { confirm: 'ಖಚಿತವಾಗಿ?' }, class: 'btn btn-xs btn-danger' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @entries if @entries.respond_to?(:total_pages) %>
