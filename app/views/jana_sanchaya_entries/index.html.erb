<div class="community-dictionary-page" style="max-width: 900px; margin: 0 auto;">
  <h1 style="color: #7b1fa2; margin-bottom: 5px; font-size: 24px;">
    <span class="glyphicon glyphicon-book"></span> ಜನಸಂಚಯ - ಸಮುದಾಯ ನಿಘಂಟು
  </h1>
  <p style="font-size: 14px; color: #666; margin-bottom: 20px;">
    ಕನ್ನಡ ಮತ್ತು ಅದರ ಉಪಭಾಷೆಗಳ ಪದಗಳ ಸಮುದಾಯ ಸಂಗ್ರಹ. 
    ಒಟ್ಟು <%= @entries.count %> ನಮೂದುಗಳು.
    <%= link_to 'ಹೊಸ ಪದ ಸೇರಿಸಿ', new_jana_sanchaya_entry_path, style: 'color: #e65100; font-weight: bold;' %>
  </p>

  <div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
    <%= form_tag community_path, method: :get, style: 'display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;' do %>
      <div style="flex: 1; min-width: 140px;">
        <%= label_tag :dialect, 'ಉಪಭಾಷೆ', style: 'font-size: 12px; font-weight: bold;' %>
        <%= select_tag :dialect, options_for_select(Dialect.alphabetical.pluck(:kannada_name, :id), params[:dialect]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
      </div>
      <div style="flex: 1; min-width: 140px;">
        <%= label_tag :ecological_domain, 'ಪರಿಸರ ಕ್ಷೇತ್ರ', style: 'font-size: 12px; font-weight: bold;' %>
        <%= select_tag :ecological_domain, options_for_select(JanaSanchayaEntry::ECOLOGICAL_DOMAINS, params[:ecological_domain]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
      </div>
      <div style="flex: 1; min-width: 140px;">
        <%= label_tag :root_language, 'ಮೂಲ ಭಾಷೆ', style: 'font-size: 12px; font-weight: bold;' %>
        <%= select_tag :root_language, options_for_select(JanaSanchayaEntry::ROOT_LANGUAGES, params[:root_language]), { prompt: 'ಎಲ್ಲಾ', class: 'form-control input-sm' } %>
      </div>
      <div>
        <%= check_box_tag :show_all, 'true', params[:show_all] == 'true' %>
        <%= label_tag :show_all, 'ಅನುಮೋದಿಸದವು ಸೇರಿ', style: 'font-size: 12px;' %>
      </div>
      <div>
        <%= submit_tag 'ಫಿಲ್ಟರ್', class: 'btn btn-sm btn-primary', style: 'font-size: 12px;' %>
      </div>
    <% end %>
  </div>

  <% if @entries.any? %>
    <% @entries.each do |entry| %>
      <div class="search-result-item" data-entry-id="<%= entry.id %>" style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #9c27b0;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 200px;">
            <h4 style="margin: 0 0 5px 0; font-size: 20px;"><strong><%= entry.word %></strong></h4>
            <% if entry.transliteration.present? %>
              <span style="font-size: 13px; color: #888;">/<%= entry.transliteration %>/</span>
            <% end %>
            <p style="font-size: 18px; margin: 8px 0;"><%= entry.meaning %></p>

            <% if entry.meaning_in_english.present? %>
              <p style="font-size: 14px; color: #555; font-style: italic;"><%= entry.meaning_in_english %></p>
            <% end %>

            <% if entry.pos.present? %>
              <span style="display: inline-block; background: #e8eaf6; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #283593;"><%= entry.pos %></span>
            <% end %>

            <% if entry.is_dialect && (entry.dialect&.kannada_name || entry.dialect_name).present? %>
              <span style="display: inline-block; background: #fff8e1; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #f57f17; margin-left: 5px;">
                🏷️ <%= entry.dialect&.kannada_name || entry.dialect_name %>
                <% if entry.dialect_place.present? %> (<%= entry.dialect_place %>)<% end %>
              </span>
            <% end %>

            <% if entry.ecological_domain.present? %>
              <span style="display: inline-block; background: #e8f5e9; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #2e7d32; margin-left: 5px;">
                🌿 <%= entry.ecological_domain %>
              </span>
            <% end %>

            <%# Etymology fields %>
            <% if entry.root_language.present? %>
              <span style="display: inline-block; background: #fce4ec; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #c62828; margin-left: 5px;">
                📖 <%= entry.root_language %>
                <% if entry.root_word.present? %>: <%= entry.root_word %><% end %>
              </span>
            <% end %>

            <% if entry.synonyms.present? %>
              <p style="font-size: 13px; color: #1565c0; margin: 5px 0;"><strong>ಪರ್ಯಾಯ ಪದಗಳು:</strong> <%= entry.synonyms %></p>
            <% end %>
            <% if entry.antonyms.present? %>
              <p style="font-size: 13px; color: #c62828; margin: 5px 0;"><strong>ವಿರುದ್ಧಾರ್ಥಕ:</strong> <%= entry.antonyms %></p>
            <% end %>
            <% if entry.usage_example.present? %>
              <p style="font-size: 13px; color: #555; margin: 5px 0; font-style: italic;">"<%= entry.usage_example %>"</p>
            <% end %>
            <% if entry.cognates.present? %>
              <p style="font-size: 12px; color: #e91e63; margin: 5px 0;"><strong>ಸಹಜ ಪದಗಳು:</strong> <%= entry.cognates %></p>
            <% end %>
            <% if entry.etymology.present? %>
              <p style="font-size: 12px; color: #555; margin: 5px 0; background: #fce4ec; padding: 3px 6px; border-radius: 4px;"><strong>📖 ವ್ಯುತ್ಪತ್ತಿ:</strong> <%= entry.etymology %></p>
            <% end %>
            <% if entry.cultural_notes.present? %>
              <p style="font-size: 12px; color: #555; margin: 5px 0; background: #fff3e0; padding: 5px 8px; border-radius: 4px;"><strong>📝</strong> <%= entry.cultural_notes %></p>
            <% end %>

            <p style="font-size: 11px; color: #aaa; margin: 10px 0 0 0;">
              ಕೊಡುಗೆದಾರ: <%= entry.contributor_name.presence || 'ಅಜ್ಞಾತ' %>
              <% if entry.current_place.present? %> | 📍 <%= entry.current_place %><% end %>
              <% if entry.dialect_place.present? && !entry.is_dialect %> | 🗺️ <%= entry.dialect_place %><% end %>
            </p>
          </div>

          <div class="voting-section" style="text-align: center; min-width: 80px; padding-top: 5px;">
            <button type="button" class="btn btn-sm btn-default jana-vote-up" data-entry-id="<%= entry.id %>" style="display: block; margin-bottom: 5px; width: 80px;" title="ಒಪ್ಪಿಕೊಳ್ಳು">
              <span class="glyphicon glyphicon-thumbs-up" style="color: #4caf50;"></span>
              <span class="vote-count-up"><%= entry.votes_up %></span>
            </button>
            <button type="button" class="btn btn-sm btn-default jana-vote-down" data-entry-id="<%= entry.id %>" style="display: block; width: 80px;" title="ಅಸಮ್ಮತಿ">
              <span class="glyphicon glyphicon-thumbs-down" style="color: #f44336;"></span>
              <span class="vote-count-down"><%= entry.votes_down %></span>
            </button>
            <span class="vote-message" style="font-size: 10px; color: #888; display: block; margin-top: 3px;"></span>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div style="text-align: center; padding: 40px; background: #f9f9f9; border-radius: 8px;">
      <p style="font-size: 16px; color: #888;">ಯಾವುದೇ ನಮೂದುಗಳಿಲ್ಲ.</p>
      <p><%= link_to 'ಮೊದಲ ಪದ ಸೇರಿಸಿ', new_jana_sanchaya_entry_path, class: 'btn btn-warning', style: 'font-size: 16px;' %></p>
    </div>
  <% end %>
</div>

<script>
(function() {
  document.querySelectorAll('.jana-vote-up, .jana-vote-down').forEach(function(button) {
    button.addEventListener('click', function() {
      var entryId = this.getAttribute('data-entry-id');
      var isUp = this.classList.contains('jana-vote-up');
      var voteType = isUp ? 'up' : 'down';
      var container = this.closest('.voting-section');
      var messageEl = container.querySelector('.vote-message');

      fetch('/jana_sanchaya_entries/' + entryId + '/vote', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : ''
        },
        body: JSON.stringify({ vote_type: voteType })
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        if (data.success) {
          container.querySelector('.vote-count-up').textContent = data.votes_up;
          container.querySelector('.vote-count-down').textContent = data.votes_down;
          messageEl.textContent = 'ಧನ್ಯವಾದಗಳು!';
          messageEl.style.color = '#4caf50';
        } else {
          messageEl.textContent = 'ಈಗಾಗಲೇ ಮತದಾನ ಮಾಡಿದ್ದೀರಿ';
          messageEl.style.color = '#ff9800';
        }
      })
      .catch(function() {
        messageEl.textContent = 'ದೋಷ ಸಂಭವಿಸಿದೆ';
        messageEl.style.color = '#f44336';
      });
    });
  });
})();
</script>
